<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme — Compose handles all theming via MaterialTheme.
         Theme.AppCompat.Light.NoActionBar is the correct parent for Compose on API 35+ -->
    <style name="Theme.SecureMessenger" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
